<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@+id/navigation_home">

    <fragment
        android:id="@+id/navigation_home"
        android:name="com.example.appmobile.ui.accueil.home.HomeFragment"
        android:label="@string/title_home"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/navigation_camera"
        android:name="com.example.appmobile.ui.accueil.camera.CameraFragment"
        android:label="@string/camera"
        tools:layout="@layout/fragment_camera" />

    <fragment
        android:id="@+id/navigation_berceau"
        android:name="com.example.appmobile.ui.accueil.berceau.BerceauFragment"
        android:label="@string/berceau"
        tools:layout="@layout/fragment_berceau" />

    <fragment
        android:id="@+id/navigation_client"
        android:name="com.example.appmobile.ui.accueil.client.ClientFragment"
        android:label="@string/client"
        tools:layout="@layout/fragment_client" />

    <fragment
        android:id="@+id/navigation_bebe"
        android:name="com.example.appmobile.ui.accueil.bebe.BebeFragment"
        android:label="@string/bebe"
        tools:layout="@layout/fragment_bebe" />
</navigation>