<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="20dp">



    <!-- Titre -->
    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/consultation_b_b"
        android:layout_gravity="center"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:gravity="center"
        android:layout_marginBottom="10dp"/>

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:id="@+id/lait_ll"
            android:orientation="vertical"
            android:padding="10dp"
            android:layout_margin="10dp"
            android:layout_width="0dp"
            android:layout_weight="1"

            android:background="@drawable/incline"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/style_tv_sous_title_post"
                android:layout_gravity="center"
                android:textSize="20sp"
                android:textColor="@color/black"
                android:text="@string/lait" />
            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:layout_marginVertical="10dp"
                android:src="@drawable/lait_bebe"
                android:contentDescription="@string/temperature">
            </ImageView>

            <EditText
                android:id="@+id/lait_edt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/style_tv_sous_title_post"
                android:textSize="25sp"
                android:layout_gravity="center"
                android:textColor="@color/black"
                android:background="@android:color/transparent"
                android:inputType="none"
                android:text="@string/_0_00"
                android:focusable="false"
                android:focusableInTouchMode="false" />


        </LinearLayout>

        <LinearLayout
            android:id="@+id/dormir_ll"
            android:orientation="vertical"
            android:padding="10dp"
            android:layout_margin="10dp"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:background="@drawable/incline"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/style_tv_sous_title_post"
                android:textSize="20sp"
                android:layout_gravity="center"
                android:textColor="@color/black"
                android:text="@string/dormir" />
            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/bebe_dormit"
                android:layout_gravity="center"
                android:layout_marginVertical="10dp"
                android:contentDescription="@string/temperature">
            </ImageView>

            <EditText
                android:id="@+id/dormir_edt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/style_tv_sous_title_post"
                android:textSize="25sp"
                android:textColor="@color/black"
                android:inputType="none"
                android:layout_gravity="center"
                android:text="@string/_0_00"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:background="@android:color/transparent" />                />

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:id="@+id/repas_ll"
            android:orientation="vertical"
            android:padding="10dp"
            android:layout_margin="10dp"
            android:layout_width="0dp"
            android:layout_weight="1"

            android:background="@drawable/incline"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/style_tv_sous_title_post"
                android:layout_gravity="center"
                android:textSize="20sp"
                android:textColor="@color/black"
                android:text="@string/repas" />
            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:layout_marginVertical="10dp"
                android:src="@drawable/repas_bebe"
                android:contentDescription="@string/temperature">
            </ImageView>

            <EditText
                android:id="@+id/repas_edt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/style_tv_sous_title_post"
                android:textSize="25sp"
                android:layout_gravity="center"
                android:textColor="@color/black"
                android:background="@android:color/transparent"
                android:inputType="none"
                android:text="@string/_0_00"
                android:focusable="false"
                android:focusableInTouchMode="false" />



        </LinearLayout>

        <LinearLayout
            android:id="@+id/couche_ll"
            android:orientation="vertical"
            android:padding="10dp"
            android:layout_margin="10dp"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:background="@drawable/incline"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/style_tv_sous_title_post"
                android:textSize="20sp"
                android:layout_gravity="center"
                android:textColor="@color/black"
                android:text="@string/couche" />
            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/couche_bebe"
                android:layout_gravity="center"
                android:layout_marginVertical="10dp"
                android:contentDescription="@string/temperature">
            </ImageView>

            <EditText
                android:id="@+id/couche_edt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/style_tv_sous_title_post"
                android:textSize="25sp"
                android:layout_gravity="center"
                android:textColor="@color/black"
                android:background="@android:color/transparent"
                android:inputType="none"
                android:text="@string/_0_00"
                android:focusable="false"
                android:focusableInTouchMode="false" />
        </LinearLayout>
    </LinearLayout>



</LinearLayout>
